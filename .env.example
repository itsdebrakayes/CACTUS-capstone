# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_ID=your_app_id_here

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
OAUTH_SERVER_URL=https://your-oauth-server.example.com
OWNER_OPEN_ID=your_owner_open_id_here

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cactus

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# Public token — starts with pk.  Never commit your real token to source control.
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=noreply@example.com

# ─── Internal / Manus forge API (optional) ───────────────────────────────────
BUILT_IN_FORGE_API_URL=https://your-forge-api.example.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here
