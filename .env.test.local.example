# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_ID=your_app_id_here

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
# Server-side: OAuth back-end used to exchange codes and verify tokens
OAUTH_SERVER_URL=https://your-oauth-server.example.com
# Client-side: OAuth portal URL shown to users for the login redirect
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com
OWNER_OPEN_ID=your_owner_open_id_here

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cactus_test

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# Public token — starts with pk.  Never commit your real token to source control.
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=noreply@example.com

# ─── Internal / Manus forge API (optional) ───────────────────────────────────
# Server-side Forge API (AI / LLM features)
BUILT_IN_FORGE_API_URL=https://your-forge-api.example.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here
# Client-side Forge API (Google Maps proxy)
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key_here
